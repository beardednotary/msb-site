# Mailchimp — copy this to .env.local and fill in your values
# API key from: Mailchimp → Account → Extras → API keys
MAILCHIMP_API_KEY=your-api-key-here

# Audience/List ID from: Mailchimp → Audience → Settings → Audience name and defaults
# Your audience ID is: 17c9cfed74
MAILCHIMP_AUDIENCE_ID=17c9cfed74

# Server prefix — the part before .api.mailchimp.com in your API key (e.g. "us21")
MAILCHIMP_API_SERVER=us21
